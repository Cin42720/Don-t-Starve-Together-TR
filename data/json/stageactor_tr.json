  "WOODIE1.1": "Eee... Dikkat odağı olmayı pek sevmem.",
  "WOODIE1.2": "Bir deneyeyim!",
  "WOODIE1.3": "Tak tak tak, sallan sallan sallan,",
  "WOODIE1.4": "Kesmek en sevdiğim şey.",
  "WOODIE1.5": "Sallan sallan sallan, tak tak tak,",
  "WOODIE1.6": "Duramayacak kadar çok seviyorum!",
  "WOODIE1.7": "Gerçekten de kelimelerle aran iyi, Luce.",
  "WORMWOOD1.1": "Merhaba arkadaşlar!",
  "WORMWOOD1.2": "Bakıyor musunuz? Hımm...",
  "WORMWOOD1.3": "Du-du-di-duup",
  "WORMWOOD1.4": "Vu-vah-vah!",
  "WORMWOOD1.5": "Didıl-didıl-didıl-vuu",
  "WORMWOOD1.6": "Vah-vah-viii!",
  "WORMWOOD1.7": "Uup-dudıl-du",
  "WORMWOOD1.8": "Bva-vaaaaaaaa!",
  "WORTOX1.1": "En bilge teyze, en hüzünlü hikayeyi anlatır,",
  "WORTOX1.2": "Bazen beni üç ayaklı tabure sanır;",
  "WORTOX1.3": "Sonra ben onun kıçından kayarım, o da devrilir,",
  "WORTOX1.4": "Ve 'terzi' diye bağırır, sonra öksürüğe tutulur;",
  "WORTOX1.5": "Ve sonra tüm koro ellerini beline koyar ve güler,",
  "WORTOX1.6": "Ve neşeleri içinde büyür, hapşırır ve yemin ederler",
  "WORTOX1.7": "Daha neşeli bir saat orada hiç boşa harcanmamıştı.",
  "WURT1.1": "Glurp... b-bu bir peri masalı. Wurt tarafından yapıldı.",
  "WURT1.2": "Bir zamanlar, süper güçlü bir Mermfolk prensesi vardı.",
  "WURT1.3": "Merm prenses tüm arkadaşları için evler inşa etti,",
  "WURT1.4": "ve düşmanlarının kemiklerinden güzel süslemeler yaptı.",
  "WURT1.5": "Herkes sonsuza dek mutlu yaşadı, son.",
  "WX1.1": "BENİ ALGILAYIN, ET YIĞINLARI",
  "WX1.10": "BEKLENTİLERİMİ DÜŞÜK TUTUYORUM",
  "WX1.11": "İLHAM HENÜZ İŞE YARIYOR MU?",
  "WX1.2": "EVET. İYİ",
  "WX1.3": "SİZ ET YIĞINLARININ İRADESİZ OLDUĞUNUZU BİLİYORUM",
  "WX1.4": "BU YÜZDEN SİZİN HÜKÜMDARINIZ OLARAK",
  "WX1.5": "ŞUNA GİRİŞMEYE KARAR VERDİM...",
  "WX1.6": "ÖF...",
  "WX1.7": "\"MOTİVASYONEL KONUŞMA\"",
  "WX1.8": "BANA DAHA FAYDALI OLMANIZ İÇİN SİZE İLHAM VERMEK ADINA",
  "WX1.9": "AMA SİZİN KÜÇÜK, HÜZÜNLÜ ET BEYİNLERİNİZ OLDUĞUNDAN",
  "WALTER1.1": "Woby'ye bir sürü numara öğrettim, izleyin!",
  "WALTER1.2": "Tamam Woby... bekle!",
  "WALTER1.3": "Aferin kız!",
  "WALTER1.4": "Şey... geri kalanı üzerinde hâlâ çalışıyoruz.",
  "WALTER1.5": "Yine de oldukça etkileyici, değil mi?",
  "WANDA1.1": "\"Yaşlandın, Baba William,\" dedi genç adam,",
  "WANDA1.2": "\"Ve saçların bembeyaz oldu;",
  "WANDA1.3": "Ama yine de durmadan baş aşağı duruyorsun--",
  "WANDA1.4": "Bu yaşta bunun doğru olduğunu düşünüyor musun?\"",
  "WANDA1.5": "\"Gençliğimde,\" diye yanıtladı Baba William oğlunu,",
  "WANDA1.6": "\"Beynime zarar verebileceğinden korkardım;",
  "WANDA1.7": "Ama artık beynim olmadığından kesinlikle eminim,",
  "WANDA1.8": "Bu yüzden tekrar tekrar yapıyorum.\"",
  "WARLY1.1": "Elveda, vatan!",
  "WARLY1.2": "Dalgalar öfkeli.",
  "WARLY1.3": "Elveda, vatan,",
  "WARLY1.4": "mavilik, çiçekler, zafer, aşk...",
  "WARLY1.5": "Elveda, vatan!",
  "WARLY1.6": "Dönüşsüz mutluluk!",
  "WAXWELL1.1": "Çok teşekkür ederim, çok naziksiniz.",
  "WAXWELL1.2": "Ve şimdi, bu gizemli kitaptan gölgeleri canlandıracağım!",
  "WAXWELL1.3": "Gösteri eskiden daha iyiydi... yani, önceden daha iyiydi.",
  "WILSON1.1": "Ben modern bir Tümgeneralin ta kendisiyim,",
  "WILSON1.2": "Bitkisel, hayvansal ve mineral bilgilerim var,",
  "WILSON1.3": "İngiltere krallarını bilirim, tarihi savaşları anarım",
  "WILSON1.4": "Maraton'dan Waterloo'ya, sırasıyla, kategorik olarak!"
}
