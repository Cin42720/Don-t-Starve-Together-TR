{
  "ACT1_SCENE1.LINE1": "Perde 1.",
  "ACT1_SCENE1.LINE10": "Hiç yapmadığım o kadar çok şey var ki,",
  "ACT1_SCENE1.LINE11": "hiç görmediğim o kadar çok şey...",
  "ACT1_SCENE1.LINE12": "Her zerresini keşfetmeliyim!",
  "ACT1_SCENE1.LINE13": "Kendi hayatına başlama düşüncesi",
  "ACT1_SCENE1.LINE14": "bebeğin kalbini neşeyle doldurdu.",
  "ACT1_SCENE1.LINE15": "Ama herkes bu duyguyu paylaşmıyordu...",
  "ACT1_SCENE1.LINE16": "Böyle bir yeteneği her gün görmezsin.",
  "ACT1_SCENE1.LINE17": "Neyse ki.",
  "ACT1_SCENE1.LINE18": "En azından ağaç iyiydi.",
  "ACT1_SCENE1.LINE19": "HA HA HA HA HA!",
  "ACT1_SCENE1.LINE2": "Evet, sahne 1!",
  "ACT1_SCENE1.LINE3": "Çok uzun zaman önce, çok uzak bir diyarda",
  "ACT1_SCENE1.LINE4": "garip bir büyü havayı doldurdu,",
  "ACT1_SCENE1.LINE5": "ve bir porselen bebek canlandı.",
  "ACT1_SCENE1.LINE6": "Ahh.",
  "ACT1_SCENE1.LINE7": "Ellerimi hareket ettirebiliyor muyum? Ayaklarımı da!",
  "ACT1_SCENE1.LINE8": "Canlı olmak böyle bir şey mi?",
  "ACT1_SCENE1.LINE9": "Ve yaşanacak ne büyük bir dünya!",
  "ACT1_SCENE2.LINE1": "Perde 1!",
  "ACT1_SCENE2.LINE10": "Dünya tehlikelerle dolu",
  "ACT1_SCENE2.LINE11": "senin gibi narin biri için.",
  "ACT1_SCENE2.LINE12": "Porselenden bir kız için burası hiç de uygun değil!",
  "ACT1_SCENE2.LINE13": "Ne yapılması gerektiğini biliyorum,",
  "ACT1_SCENE2.LINE14": "sana güzel bir zırh takımı yapacağım.",
  "ACT1_SCENE2.LINE15": "Onu giy, hiçbir şeyden korkmana gerek kalmayacak.",
  "ACT1_SCENE2.LINE16": "Ve böylece, Demirci örsüne gitti,",
  "ACT1_SCENE2.LINE17": "ve ağır bir demir zırh takımı dövdü.",
  "ACT1_SCENE2.LINE18": "Küçük oyuncak bebek onu giydi,",
  "ACT1_SCENE2.LINE19": "ama içinde zar zor hareket edebildiğini gördü.",
  "ACT1_SCENE2.LINE2": "İkinci Sahne, değil mi?",
  "ACT1_SCENE2.LINE20": "Bu zırh o kadar ağır ki,",
  "ACT1_SCENE2.LINE21": "sanki ben sadece...",
  "ACT1_SCENE2.LINE22": "Küçük oyuncak bebek hava kararana kadar bekledi,",
  "ACT1_SCENE2.LINE23": "ve Demirci uykuya daldı.",
  "ACT1_SCENE2.LINE24": "Sonra ağır zırhı çıkardı,",
  "ACT1_SCENE2.LINE25": "ve geceye doğru süzüldü",
  "ACT1_SCENE2.LINE26": "macerasına başlamak için.",
  "ACT1_SCENE2.LINE27": "Kız kardeş... bana bir şey mi anlatmaya çalışıyorsun?",
  "ACT1_SCENE2.LINE28": "O demirci beni gerçekten güldürüyor.",
  "ACT1_SCENE2.LINE29": "Bilmem, oyunculuk biraz abartılıydı.",
  "ACT1_SCENE2.LINE3": "Küçük bebek önce Demircinin yanına koştu,",
  "ACT1_SCENE2.LINE30": "HA HA HA HA HA!",
  "ACT1_SCENE2.LINE31": "Ama o ağacı gördün mü?",
  "ACT1_SCENE2.LINE32": "Değil mi? Ne duruş ama!",
  "ACT1_SCENE2.LINE4": "Demirci henüz küçükken",
  "ACT1_SCENE2.LINE5": "bebeğe bakmaya başlamıştı.",
  "ACT1_SCENE2.LINE6": "Demirci, bebeğin canlandığını görünce",
  "ACT1_SCENE2.LINE7": "çok sevindi,",
  "ACT1_SCENE2.LINE8": "ama sevinci çabucak korkuya dönüştü.",
  "ACT1_SCENE2.LINE9": "Küçük bebek, dikkatli olmalısın!",
  "ACT1_SCENE3.LINE1": "Perde 1.",
  "ACT1_SCENE3.LINE10": "ve ağaçlar ile çiçekler onun emriyle açtı.",
  "ACT1_SCENE3.LINE11": "Kalabalıklar onu geçerken izlemek için toplandı.",
  "ACT1_SCENE3.LINE12": "Şu adama bakın hele.",
  "ACT1_SCENE3.LINE13": "Ne gösterişçi ama.",
  "ACT1_SCENE3.LINE14": "Affedersiniz, bayım!",
  "ACT1_SCENE3.LINE15": "Çiçekleri nasıl açtırdınız?",
  "ACT1_SCENE3.LINE16": "Ah, bu sihir, tatlım!",
  "ACT1_SCENE3.LINE17": "Ve ben sıradan bir \"bay\" değilim,",
  "ACT1_SCENE3.LINE18": "bu diyarın Kralı!",
  "ACT1_SCENE3.LINE19": "Ah! Çok üzgünüm,",
  "ACT1_SCENE3.LINE2": "Sahne 3!",
  "ACT1_SCENE3.LINE20": "Daha önce hiç kral görmemiştim,",
  "ACT1_SCENE3.LINE21": "Nasıl göründüklerini bilmiyordum.",
  "ACT1_SCENE3.LINE22": "Ho, ho!",
  "ACT1_SCENE3.LINE23": "Doğrusunu söylemek gerekirse,",
  "ACT1_SCENE3.LINE24": "Daha önce hiç bu kadar canlı",
  "ACT1_SCENE3.LINE25": "bir porselen bebekle tanışmamıştım.",
  "ACT1_SCENE3.LINE26": "Belki birlikte seyahat edebiliriz?",
  "ACT1_SCENE3.LINE27": "Bu yol uzun ve oldukça yalnızlaştırıcı olabilir.",
  "ACT1_SCENE3.LINE28": "Ne harika!",
  "ACT1_SCENE3.LINE29": "Yol boyunca bana büyünü öğretir misin?",
  "ACT1_SCENE3.LINE3": "Evet, sahne 3.",
  "ACT1_SCENE3.LINE30": "Memnuniyetle.",
  "ACT1_SCENE3.LINE31": "Konu kızışıyor.",
  "ACT1_SCENE3.LINE32": "Sanırım iğrençleşiyor demek istedin.",
  "ACT1_SCENE3.LINE33": "HA HA HA HA HA!",
  "ACT1_SCENE3.LINE4": "Küçük bebek yürüdü de yürüdü,",
  "ACT1_SCENE3.LINE5": "kırların yerini işlek bir şehre",
  "ACT1_SCENE3.LINE6": "bırakmasına hayret ederek.",
  "ACT1_SCENE3.LINE7": "Bir gün, altın taçlı bir adama rastladı,",
  "ACT1_SCENE3.LINE8": "yolda seyahat ederken.",
  "ACT1_SCENE3.LINE9": "Parmağını havada döndürdü,",
  "ACT2_SCENE4.LINE1": "Aradan sonra geri döndük.",
  "ACT2_SCENE4.LINE10": "Biraz keyifsizim.",
  "ACT2_SCENE4.LINE11": "Korkarım yapamam,",
  "ACT2_SCENE4.LINE12": "bu gece dolunay var!",
  "ACT2_SCENE4.LINE13": "Aman Tanrım, asla yapamam!",
  "ACT2_SCENE4.LINE14": "Çarşambaları büyü öğretmenin uğursuzluk getirdiğini bilmiyor musunuz?",
  "ACT2_SCENE4.LINE15": "Oyuncak bebek Kral'a inandı,",
  "ACT2_SCENE4.LINE16": "bu yüzden bekledi. Ve bekledi...",
  "ACT2_SCENE4.LINE17": "Bir güne kadar,",
  "ACT2_SCENE4.LINE18": "Kral'ın şatosunda gizli bir oda buldu,",
  "ACT2_SCENE4.LINE19": "ve onun sırrını keşfetti.",
  "ACT2_SCENE4.LINE2": "Evet, 2. Perdeye geçelim!",
  "ACT2_SCENE4.LINE20": "Oh! Merhaba, siz kimsiniz?",
  "ACT2_SCENE4.LINE21": "Benim bir adım yok,",
  "ACT2_SCENE4.LINE22": "Sadece sihirli ayna olarak bilinirim.",
  "ACT2_SCENE4.LINE23": "Kralınız gücümü çaldı",
  "ACT2_SCENE4.LINE24": "ve beni saklı tuttu.",
  "ACT2_SCENE4.LINE25": "Özgürlüğe nasıl da açım.",
  "ACT2_SCENE4.LINE26": "Dış dünyadan sadece bir tat...",
  "ACT2_SCENE4.LINE27": "O Kral'a güvenmediğimi biliyordum!",
  "ACT2_SCENE4.LINE28": "Yuh! Tısss!",
  "ACT2_SCENE4.LINE29": "Ne korkunç!",
  "ACT2_SCENE4.LINE3": "Sahne 1.",
  "ACT2_SCENE4.LINE30": "Endişelenme,",
  "ACT2_SCENE4.LINE31": "Bu yalnız yerden ayrılmana yardım edeceğim.",
  "ACT2_SCENE4.LINE32": "Hayır! Sırrım keşfedildi!",
  "ACT2_SCENE4.LINE33": "Anlaşmamıza uymadın.",
  "ACT2_SCENE4.LINE34": "Şimdi bu cesur oyuncak bebek geldi",
  "ACT2_SCENE4.LINE35": "beni bu hapishaneden kurtarmak için.",
  "ACT2_SCENE4.LINE36": "Geri çekil, diyorum!",
  "ACT2_SCENE4.LINE37": "Sihrin benim, ayna.",
  "ACT2_SCENE4.LINE38": "Asla gitmene izin vermeyeceğim!",
  "ACT2_SCENE4.LINE39": "Sssihirli patlama!",
  "ACT2_SCENE4.LINE4": "Zaman geçti ve Kral küçük bebeği getirdi",
  "ACT2_SCENE4.LINE40": "Hayır!",
  "ACT2_SCENE4.LINE41": "İiiip! Kaybolma zamanı!",
  "ACT2_SCENE4.LINE42": "Sssihirli kaçış!",
  "ACT2_SCENE4.LINE43": "Acaba ne kadarını hatırlıyor?",
  "ACT2_SCENE4.LINE44": "Ağaca gerçekten üzüldüm.",
  "ACT2_SCENE4.LINE45": "Çok duygusal.",
  "ACT2_SCENE4.LINE5": "birçok harika maceraya atıldı.",
  "ACT2_SCENE4.LINE6": "Oyuncak bebek sık sık Kral'ın büyüsünü sorar,",
  "ACT2_SCENE4.LINE7": "ve ona öğretip öğretmeyeceğini merak ederdi,",
  "ACT2_SCENE4.LINE8": "ama Kral her zaman bir bahane uydururdu.",
  "ACT2_SCENE4.LINE9": "Bugün olmaz küçük bebek,",
  "ACT2_SCENE5.LINE1": "Oh iyi, ağaç burada.",
  "ACT2_SCENE5.LINE10": "Her zamankinden daha iyi!",
  "ACT2_SCENE5.LINE11": "Sana verebileceğim gücü verdim,",
  "ACT2_SCENE5.LINE12": "ama Kral'ın benden çaldığı büyü olmadan,",
  "ACT2_SCENE5.LINE13": "seni tamamen iyileştiremem.",
  "ACT2_SCENE5.LINE14": "Onu bulmalısın, ama dikkatli ol.",
  "ACT2_SCENE5.LINE15": "Onun hain yollarını kendin gördün.",
  "ACT2_SCENE5.LINE16": "Onunla konuşacağım.",
  "ACT2_SCENE5.LINE17": "Ve sana şunu vaat ediyorum, ayna;",
  "ACT2_SCENE5.LINE18": "İkimizi de yeniden bütün göreceğim.",
  "ACT2_SCENE5.LINE2": "Bir an için endişelendim.",
  "ACT2_SCENE5.LINE3": "Çabuk! Perde 2!",
  "ACT2_SCENE5.LINE4": "Sahne 2!",
  "ACT2_SCENE5.LINE5": "Zamanın henüz bitmedi, küçük bebek.",
  "ACT2_SCENE5.LINE6": "Uyan!",
  "ACT2_SCENE5.LINE7": "Ben... yaşıyorum!",
  "ACT2_SCENE5.LINE8": "Ama... farklı hissediyorum...",
  "ACT2_SCENE5.LINE9": "Yepyeni gibi!",
  "ACT2_SCENE6.LINE1": "Perde 2!",
  "ACT2_SCENE6.LINE10": "Tek bacaklı yetimler için bir yuva inşaatı!",
  "ACT2_SCENE6.LINE11": "Ve... ee... şey...",
  "ACT2_SCENE6.LINE12": "Gözlüklü bir adama vurmazsın, değil mi?",
  "ACT2_SCENE6.LINE13": "Eski dostunu görmekten bu kadar mı korkuyorsun?",
  "ACT2_SCENE6.LINE14": "Küçük bebek mi? Olamaz! Ben... yani, sen...",
  "ACT2_SCENE6.LINE15": "Ayna beni hayata döndürdü.",
  "ACT2_SCENE6.LINE16": "Onun hissettiklerini hissedebiliyorum...",
  "ACT2_SCENE6.LINE17": "Birbirimize yeniden bütün olmamız için yardım edeceğiz.",
  "ACT2_SCENE6.LINE18": "Ama bunun için gücüne ihtiyacım olacak.",
  "ACT2_SCENE6.LINE19": "Benim gücüm mü? Asla!",
  "ACT2_SCENE6.LINE2": "Sahne 3!",
  "ACT2_SCENE6.LINE20": "Bbbüyü uzaklara!",
  "ACT2_SCENE6.LINE21": "Hayır!",
  "ACT2_SCENE6.LINE22": "Ve bununla birlikte, Kral büyüsünü kullandı",
  "ACT2_SCENE6.LINE23": "kendini ve tahtını çok uzaklara saklamak için,",
  "ACT2_SCENE6.LINE24": "küçük bebeğin onu asla bulamayacağını düşündüğü yere.",
  "ACT2_SCENE6.LINE3": "Bebek, Kral'ı bulmak için kaleyi aradı,",
  "ACT2_SCENE6.LINE4": "ve onu tahtının arkasına sinmiş halde buldu.",
  "ACT2_SCENE6.LINE5": "Beni rahat bırak, canavar!",
  "ACT2_SCENE6.LINE6": "B-ben sadece zavallı, çelimsiz bir yaşlı adamım!",
  "ACT2_SCENE6.LINE7": "Uhm... ve annem hasta,",
  "ACT2_SCENE6.LINE8": "ve ona bakacak tek kişi benim!",
  "ACT2_SCENE6.LINE9": "Ve... ah biliyorum! Tam şimdi planlıyordum",
  "ACT3_SCENE7.LINE1": "Final Perde!",
  "ACT3_SCENE7.LINE10": "Kral tahtında ne kasvetli!",
  "ACT3_SCENE7.LINE11": "Neşelen hey, neşelen hoy,",
  "ACT3_SCENE7.LINE12": "soytarılar çağırmış, bizi izlesin boy boy!",
  "ACT3_SCENE7.LINE13": "Uzaktan yakından bizi çağırdı,",
  "ACT3_SCENE7.LINE14": "tahtta oturan için gösteri yapacağız!",
  "ACT3_SCENE7.LINE15": "Kral sıkılmış mı, öyle mi?",
  "ACT3_SCENE7.LINE16": "Belki de dikkatsizleşmiştir.",
  "ACT3_SCENE7.LINE17": "Eğer bu soytarıları takip edersem,",
  "ACT3_SCENE7.LINE18": "beni doğrudan ona götürebilirler...",
  "ACT3_SCENE7.LINE19": "Ne tuhaf, birden gölgelendiğimi hissediyorum.",
  "ACT3_SCENE7.LINE2": "Sahne 1!",
  "ACT3_SCENE7.LINE20": "Muhtemelen hiçbir şeydir!",
  "ACT3_SCENE7.LINE3": "Çok heyecan verici!",
  "ACT3_SCENE7.LINE4": "Neredeyse bitti!",
  "ACT3_SCENE7.LINE5": "Oyuncak bebek her yeri aradı durdu,",
  "ACT3_SCENE7.LINE6": "ama zaman geçtikçe,",
  "ACT3_SCENE7.LINE7": "Kral kazanmış gibi görünüyordu.",
  "ACT3_SCENE7.LINE8": "Ta ki bir gün...",
  "ACT3_SCENE7.LINE9": "Neşelen hey, neşelen hoy,",
  "ACT3_SCENE8.LINE1": "Perde 3!",
  "ACT3_SCENE8.LINE10": "Kralım!",
  "ACT3_SCENE8.LINE11": "İzin verin de sizi şen şakrak soytarılıklarımla eğlendireyim!",
  "ACT3_SCENE8.LINE12": "Eyvah-!",
  "ACT3_SCENE8.LINE13": "Heyecan içinde,",
  "ACT3_SCENE8.LINE14": "sakar soytarı Kral'ı tahtından düşürdü.",
  "ACT3_SCENE8.LINE15": "Görünüşe göre yıllar",
  "ACT3_SCENE8.LINE16": "Kral'a nazik davranmamıştı,",
  "ACT3_SCENE8.LINE17": "çünkü yere düştüğünde,",
  "ACT3_SCENE8.LINE18": "narin bedeni toza dönüştü.",
  "ACT3_SCENE8.LINE19": "Hayıııır!",
  "ACT3_SCENE8.LINE2": "Sahne 2!",
  "ACT3_SCENE8.LINE20": "Ah... Sanırım artık Kral benim!",
  "ACT3_SCENE8.LINE21": "Tahtta yeterince uzun süredir bir soytarı vardı.",
  "ACT3_SCENE8.LINE22": "belki de bu krallığın ihtiyacı olan...",
  "ACT3_SCENE8.LINE23": "bir Kraliçe'dir.",
  "ACT3_SCENE8.LINE24": "Özel efektler gitgide daha iyi oluyor.",
  "ACT3_SCENE8.LINE25": "Keşke oyuncular için de aynısını söyleyebilseydim.",
  "ACT3_SCENE8.LINE26": "HA HA HA HA HA!",
  "ACT3_SCENE8.LINE27": "Ağaçtan yine kusursuz bir performans.",
  "ACT3_SCENE8.LINE28": "Nasıl başarıyorlar bunu?!",
  "ACT3_SCENE8.LINE29": "Soytarı!",
  "ACT3_SCENE8.LINE3": "Yolculuk uzun olsa da,",
  "ACT3_SCENE8.LINE4": "tıpkı bebeğin tahmin ettiği gibiydi.",
  "ACT3_SCENE8.LINE5": "Bebek, soytarıyı takip etti",
  "ACT3_SCENE8.LINE6": "Kral'ın taht odasına kadar,",
  "ACT3_SCENE8.LINE7": "görünmemeye özen göstererek.",
  "ACT3_SCENE8.LINE8": "Yeterince uzun sürdü gelmen!",
  "ACT3_SCENE8.LINE9": "Beklemekten yorulmuştum.",
  "ACT3_SCENE9.LINE1": "Son sahne!",
  "ACT3_SCENE9.LINE10": "Henüz eski halime dönemem.",
  "ACT3_SCENE9.LINE11": "Sana bir söz verdim, ayna,",
  "ACT3_SCENE9.LINE12": "ve onu yerine getireceğim.",
  "ACT3_SCENE9.LINE13": "Seni onaracak gücü bulacağım,",
  "ACT3_SCENE9.LINE14": "ve bana verdiğin her şeyin karşılığını ödeyeceğim.",
  "ACT3_SCENE9.LINE15": "Ve böylece,",
  "ACT3_SCENE9.LINE16": "hain Kral gidip unutulduğunda,",
  "ACT3_SCENE9.LINE17": "küçük oyuncak bebek adil ve zorlu bir Kraliçe oldu.",
  "ACT3_SCENE9.LINE18": "Halk tüm diyarda sevindi,",
  "ACT3_SCENE9.LINE19": "ve sihirli ayna biliyordu",
  "ACT3_SCENE9.LINE2": "Son perdenin!",
  "ACT3_SCENE9.LINE20": "nihayet Onları özgür kılacak kişiyi bulmuşlardı.",
  "ACT3_SCENE9.LINE21": "Mutlu sonları severim.",
  "ACT3_SCENE9.LINE22": "Bittiği için mutluyum sadece.",
  "ACT3_SCENE9.LINE23": "HA HA HA HA HA!",
  "ACT3_SCENE9.LINE3": "Nihayet!",
  "ACT3_SCENE9.LINE4": "Dediğin gibi oldu, ayna.",
  "ACT3_SCENE9.LINE5": "Hayal ettiğimden çok daha fazlası oldum...",
  "ACT3_SCENE9.LINE6": "ama neden kırık kaldın?",
  "ACT3_SCENE9.LINE7": "Ne yazık ki,",
  "ACT3_SCENE9.LINE8": "Kralınızla tanışmadan çok önce paramparça olmuştum.",
  "ACT3_SCENE9.LINE9": "Onun gücüyle bile,",
  "ARTIFICER_SOLILOQUY.1": "Zanaatkar!",
  "ARTIFICER_SOLILOQUY.10": "Bu imkansız tasarımı hayata geçirsem bile,",
  "ARTIFICER_SOLILOQUY.11": "Buradan asla ayrılabileceğimden şüpheliyim.",
  "ARTIFICER_SOLILOQUY.12": "Sadece yavrularımın hayatta kalma şansı bulması için dua ediyorum,",
  "ARTIFICER_SOLILOQUY.13": "Diğer'den güvende,",
  "ARTIFICER_SOLILOQUY.14": "burada başardıklarımız sayesinde.",
  "ARTIFICER_SOLILOQUY.15": "Bu küçük umut, beni ayakta tutan tek şey",
  "ARTIFICER_SOLILOQUY.16": "bu karanlık zamanlarda.",
  "ARTIFICER_SOLILOQUY.17": "Peki yavruları tüm bunlardan sonra hayatta kaldı mı?",
  "ARTIFICER_SOLILOQUY.18": "Hayır.",
  "ARTIFICER_SOLILOQUY.19": "HA HA HA HA HA!",
  "ARTIFICER_SOLILOQUY.2": "Tüm işi yapanı mı kastediyorsun?",
  "ARTIFICER_SOLILOQUY.3": "Evet...",
  "ARTIFICER_SOLILOQUY.4": "Ne aptal ama!",
  "ARTIFICER_SOLILOQUY.5": "HA HA HA HA HA!",
  "ARTIFICER_SOLILOQUY.6": "Kaç ömür sürerdi acaba",
  "ARTIFICER_SOLILOQUY.7": "böyle bir yapıyı yontmak,",
  "ARTIFICER_SOLILOQUY.8": "ustalığımla bile mi?",
  "ARTIFICER_SOLILOQUY.9": "Kalkan Taşıyıcı, kabuğunun altında çok şey saklar.",
  "BAD_COSTUMES.1": "Bir şeyler yanlış!",
  "BAD_COSTUMES.2": "Kostümlerinizi kontrol edin!",
  "BAD_COSTUMES.3": "Geri geleceğiz.",
  "BAD_COSTUMES.4": "Doğru yaptığınızda!",
  "BLACKSMITH_SOLILOQUY.1": "\"Demirci'nin Monologu\"",
  "BLACKSMITH_SOLILOQUY.2": "İlerlemeye devam.",
  "BLACKSMITH_SOLILOQUY.3": "Ah küçük bebek, küçük bebek!",
  "BLACKSMITH_SOLILOQUY.4": "Nereye gittin?",
  "BLACKSMITH_SOLILOQUY.5": "Dışarısı senin için güvenli değil",
  "BLACKSMITH_SOLILOQUY.6": "bu koca geniş dünyada!",
  "BLACKSMITH_SOLILOQUY.7": "Eğer bozuk değilse...",
  "BLACKSMITH_SOLILOQUY.8": "Yine de tamir etmeye çalışacak.",
  "ELYTRA_SOLILOQUY.1": "Karşınızda, Elytra!",
  "ELYTRA_SOLILOQUY.10": "Sana, Metheus, Kraliçem,",
  "ELYTRA_SOLILOQUY.11": "kalbim paramparça oldu, seni hayal kırıklığına uğrattığımı bilmekten.",
  "ELYTRA_SOLILOQUY.12": "Lanetini üzerime sal,",
  "ELYTRA_SOLILOQUY.13": "sonsuz bir kederi taşıyabileyim diye.",
  "ELYTRA_SOLILOQUY.14": "Daha ne kadar keder taşıması kaldı ki?",
  "ELYTRA_SOLILOQUY.15": "Bakalım... epey zaman oldu, yani bir sonsuzluk daha mı?",
  "ELYTRA_SOLILOQUY.16": "HA HA HA HA HA!",
  "ELYTRA_SOLILOQUY.2": "Onun performansı hakkında ne dediklerini duydun mu?",
  "ELYTRA_SOLILOQUY.3": "Evet! Harikaydı!",
  "ELYTRA_SOLILOQUY.4": "HA HA HA HA HA!",
  "ELYTRA_SOLILOQUY.5": "Eğer bu sözler kulaklarına ulaşırsa, ey cüretkar kaşif,",
  "ELYTRA_SOLILOQUY.6": "o zaman tüm çabalarımız boşa gitmiş demektir.",
  "ELYTRA_SOLILOQUY.7": "Zaten tüketilmiş olanlara merhamet,",
  "ELYTRA_SOLILOQUY.8": "ve henüz Öteki tarafından alınacak olanlara da.",
  "ELYTRA_SOLILOQUY.9": "...",
  "FOOL_SOLILOQUY.1": "\"Soytarının Monologu\"",
  "FOOL_SOLILOQUY.2": "Kimi kandırdıklarını sanıyorlar?",
  "FOOL_SOLILOQUY.3": "Bir zamanlar yapmam gerektiğini düşündüğüm gibi davrandım,",
  "FOOL_SOLILOQUY.4": "Tüm kurallara uydum.",
  "FOOL_SOLILOQUY.5": "Ama kısa sürede anladım ki hayat bir oyun,",
  "FOOL_SOLILOQUY.6": "Ve ben soytarıyı oynadım!",
  "FOOL_SOLILOQUY.7": "Başım ağrıyor.",
  "FOOL_SOLILOQUY.8": "Bir soytarıyı dinlemek bunu yapar.",
  "HALFWIT_SOLILOQUY.1": "Dostlarımı gördünüz mü?",
  "HALFWIT_SOLILOQUY.2": "Üç kişi gelmiştik.",
  "HALFWIT_SOLILOQUY.3": "Şimdi sadece ben kaldım.",
  "HALFWIT_SOLILOQUY.4": "Dostlarımı gördünüz mü?",
  "KING_SOLILOQUY.1": "\"Kralın Monoloğu\"",
  "KING_SOLILOQUY.2": "Şimdilik o Kral, her neyse.",
  "KING_SOLILOQUY.3": "Ne kadar farklı olabilirdi her şey,",
  "KING_SOLILOQUY.4": "eğer tacı hiç aramasaydım?",
  "KING_SOLILOQUY.5": "Sanırım dünya biraz daha parlak olurdu.",
  "KING_SOLILOQUY.6": "Gerçekten de ne korkunç bir düşünce.",
  "KING_SOLILOQUY.7": "Tacı taşıyan baş ağırdır.",
  "KING_SOLILOQUY.8": "Onun kafası çoğundan büyük.",
  "KNIGHT_SOLILOQUY.BIRD1_1": "Bize bir şaka anlat!",
  "KNIGHT_SOLILOQUY.BIRD1_3": "Oyalanmayı bırak!",
  "KNIGHT_SOLILOQUY.BIRD1_6": "Ne tay!",
  "KNIGHT_SOLILOQUY.BIRD2_2": "Doğrudan atın ağzından!",
  "KNIGHT_SOLILOQUY.BIRD2_4": "Biraz kısık sesli mi hissediyorsun?",
  "KNIGHT_SOLILOQUY.BIRD2_5": "Yele şovu da buraya kadarmış!",
  "KNIGHT_SOLILOQUY.BIRD_7": "HA HA HA HA HA!",
  "KNIGHT_SOLILOQUY.LINE1_KNIGHT": "...",
  "KNIGHT_SOLILOQUY.LINE2_KNIGHT": "...",
  "NO_SCRIPT.1": "Bir şeyler yanlış.",
  "NO_SCRIPT.2": "Metnin dışına çıkıyorlar!",
  "NO_SCRIPT.3": "Doğaçlama için gelmedim!",
  "NO_SCRIPT.4": "Çıktık.",
  "PRINCESS_SOLILOQUY.BIRD1_1": "Kim o?",
  "PRINCESS_SOLILOQUY.BIRD1_3": "Kraliçe mi? Daha çok şımarık bir prenses gibi!",
  "PRINCESS_SOLILOQUY.BIRD1_5": "Sakin ol, prenses. Yakında burada olacaklar.",
  "PRINCESS_SOLILOQUY.BIRD2_2": "O... at gibi görünüyor.",
  "PRINCESS_SOLILOQUY.BIRD2_6": "Evet, atlarını zapt etsinler!",
  "PRINCESS_SOLILOQUY.BIRD_4": "HA HA HA HA HA!",
  "PRINCESS_SOLILOQUY.BIRD_7": "HA HA HA HA HA!",
  "PRINCESS_SOLILOQUY.LINE10_PRINCESS": "İhtiyaç sahiplerine çevir düşüncelerini!",
  "PRINCESS_SOLILOQUY.LINE11_PRINCESS": "Yine de senin için endişelenmem, Desdemona,",
  "PRINCESS_SOLILOQUY.LINE12_PRINCESS": "çünkü bilirim ki sen her zaman geleceksin.",
  "PRINCESS_SOLILOQUY.LINE13_PRINCESS": "Ve senin sırtında,",
  "PRINCESS_SOLILOQUY.LINE14_PRINCESS": "hepimiz ocağımıza geri döneceğiz!",
  "PRINCESS_SOLILOQUY.LINE15_PRINCESS": "Böylece görüyorsun ki,",
  "PRINCESS_SOLILOQUY.LINE16_PRINCESS": "yapılacak çok iş var,",
  "PRINCESS_SOLILOQUY.LINE17_PRINCESS": "Dört Şövalyem ve benim tarafımdan.",
  "PRINCESS_SOLILOQUY.LINE1_PRINCESS": "Nerede, lütfen, maiyetim?",
  "PRINCESS_SOLILOQUY.LINE2_PRINCESS": "Sadık refakatçilerim? Yaldızlı zırhlı Şövalyelerim?",
  "PRINCESS_SOLILOQUY.LINE3_PRINCESS": "Bu topraklara tek başıma mı çıkmalıyım",
  "PRINCESS_SOLILOQUY.LINE4_PRINCESS": "senin sarsılmaz yoldaşlığın olmadan?",
  "PRINCESS_SOLILOQUY.LINE5_PRINCESS": "Gel, Pascal!",
  "PRINCESS_SOLILOQUY.LINE6_PRINCESS": "Birçok ruhla tanışacağız!",
  "PRINCESS_SOLILOQUY.LINE7_PRINCESS": "Acele et, Warren!",
  "PRINCESS_SOLILOQUY.LINE8_PRINCESS": "Haneler gelişini bekliyor!",
  "PRINCESS_SOLILOQUY.LINE9_PRINCESS": "Çabuk ol, Fermin!",
  "REPEAT_COSTUMES.1": "Şaka mı yapıyorsun?",
  "REPEAT_COSTUMES.2": "Çift mi görüyorum ben?!",
  "REPEAT_COSTUMES.3": "Yedek oyuncu yok!",
  "REUNION.1": "\"Yeniden Buluşma\"",
  "REUNION.10": "Dünya, porselenden yapılma biri için fazla tehlikeli.",
  "REUNION.11": "Ama benim için artık korkmana gerek yok.",
  "REUNION.12": "Şimdi daha güçlü bir şeyden yapıldım.",
  "REUNION.13": "Ah, demirciye ne olduğunu merak ediyordum.",
  "REUNION.14": "Kapanışı yapmak güzel.",
  "REUNION.15": "Olamaz, öylece bitemez!",
  "REUNION.2": "Ooooh, kulağa ilginç geliyor!",
  "REUNION.3": "Demirci, bebeği arıyordu,",
  "REUNION.4": "ve sonunda yolculuğu sona erdi.",
  "REUNION.5": "Küçük bebek, gerçekten sen misin?",
  "REUNION.6": "Ne kadar da değişmişsin...",
  "REUNION.7": "Benim,",
  "REUNION.8": "ama ben artık eskiden tanıdığın küçük bebek değilim.",
  "REUNION.9": "Haklıydın, Demirci.",
  "SAGE_SOLILOQUY.1": "Neyin geldiği hakkında hiçbir fikriniz yok.",
  "SAGE_SOLILOQUY.2": "Şüphesiz özel bir şey!",
  "SAGE_SOLILOQUY.3": "Sizin için bozmalı mıyım?",
  "SAGE_SOLILOQUY.4": "Yapmamalıyım!",
  "SAGE_SOLILOQUY.5": "Tamamlanana kadar beklemeniz gerekecek!",
  "SAGE_SOLILOQUY.6": "Sabır, dostlar!",
  "SAGE_SOLILOQUY.7": "SABIR.",
  "THEVAULT.BIRD1_1": "\"Görev Tamamlandı\"",
  "THEVAULT.BIRD1_3": "Ooooh skandal!",
  "THEVAULT.BIRD1_4": "Bu ne kadar trajikti...",
  "THEVAULT.BIRD2_2": "Bu bir itiraf...",
  "THEVAULT.BIRD2_5": "Evet, sadece ikisi öldü!",
  "THEVAULT.BIRD_6": "HA HA HA HA HA!",
  "THEVAULT.LINE10_ELYTRA": "Zor inanırım buna,",
  "THEVAULT.LINE11_ELYTRA": "kaldırılışına tanık olmasaydım",
  "THEVAULT.LINE12_ELYTRA": "bu aşılmaz labirentin kendim.",
